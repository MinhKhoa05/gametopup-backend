# =============================================================================
# DATABASE CONFIGURATION (MariaDB in Docker)
# =============================================================================
DB_ROOT_PASSWORD=YOUR_ROOT_PASSWORD
DB_NAME=game_topup_db
DB_USER=game_topup_user
DB_PASSWORD=YOUR_APP_PASSWORD
DB_PORT_EXTERNAL=3307
DB_PORT_INTERNAL=3306

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_PORT_EXTERNAL=5000
API_PORT_INTERNAL=8080
ASPNETCORE_ENVIRONMENT=Development

# CONNECTION STRING
# Local API -> Docker DB: Server=127.0.0.1;Port=3307;...
# Docker API -> Docker DB: Server=db;Port=3306;...
DB_CONNECTION_STRING=Server=127.0.0.1;Port=3307;Database=game_topup_db;User=game_topup_user;Password=YOUR_APP_PASSWORD;SslMode=None;

# =============================================================================
# SECURITY & AUTH (JWT)
# =============================================================================
JWT_KEY=YOUR_SECURE_JWT_KEY_MIN_32_CHARS
JWT_ISSUER=GameTopUp
JWT_AUDIENCE=GameTopUpUsers
JWT_EXPIRE_MINUTES=30

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000
